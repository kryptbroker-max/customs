# Copy this file to `.env` and fill with real credentials
# Do NOT commit your real .env to source control

# Server
PORT=3000

# SMTP settings - Zoho Mail with custom domain
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_zoho_password
FROM_EMAIL="Organization Name <noreply@yourdomain.com>"
# Custom Domain Configuration
CUSTOM_DOMAIN=yourdomain.com
ORGANIZATION_NAME=Your Organization

# Render Deployment
PUBLIC_BASE_URL=https://customsmail.onrender.com
LOGO_PUBLIC_URL=https://customsmail.onrender.com/img/logo.png
